# Copy to .env (local) or set in Netlify → Site settings → Environment variables.
# NEVER commit real secrets. These are read ONLY by the Netlify Functions
# (server-side); they are never exposed to the browser.

# ── Oracle OPERA / OHIP — room availability + rates ──
OHIP_BASE_URL=          # e.g. https://<your-ohip-host>
OHIP_CLIENT_ID=
OHIP_CLIENT_SECRET=
OHIP_HOTEL_ID=          # the property/hotel code in OPERA
OHIP_APP_KEY=           # OHIP x-app-key

# ── Payment gateway (choose one) ──
PAYMENT_PROVIDER=       # paymongo | stripe
PAYMONGO_SECRET_KEY=    # if PayMongo
STRIPE_SECRET_KEY=      # if Stripe
